@font-face {
    font-family: 'encode-sans';
    src: url('/public/EncodeSans.ttf') format('truetype')
}

:root {
    --red: #af4c2f;
    --brown: #c9934b;
    --black: #000000;
}

body {
    background-color: var(--brown);
}

html {
    font-size: 62.5%;
    font-family: 'encode-sans';
    color: var(--black);
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

h1 {
    font-weight: 500;
    font-size: 5rem;
}

h2 {
    font-weight: 400;
    font-size: 4rem;
}

h3 {
    font-weigh: 400;
    font-size: 3rem;
}
